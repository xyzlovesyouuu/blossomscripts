local function tween(object, info, properties)
    local t = TweenService:Create(object, info, properties)
    t:Play()
    return t
end

local function applyHoverEffect(button, defaultColor, hoverColor)
    button.MouseEnter:Connect(function()
        tween(button, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = hoverColor})
    end)
    button.MouseLeave:Connect(function()
        tween(button, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = defaultColor})
    end)
end

