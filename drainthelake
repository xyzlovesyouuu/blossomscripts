-- Global değil lokal olarak atıyoruz (Yukarıdaki forward declaration'ı doldurur)
function loadMainScript()

    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Workspace = game:GetService("Workspace")
    local Players = game:GetService("Players")
    local CoreGui = game:GetService("CoreGui")

    local VerdantRemotes = ReplicatedStorage:FindFirstChild("VerdantRemotes")
    local PouredRemote = VerdantRemotes and VerdantRemotes:FindFirstChild("VDT_Bucket.Poured")
    local TakeRemote = VerdantRemotes and VerdantRemotes:FindFirstChild("VDT_Tokens.Take")
    local UsedRemote = VerdantRemotes and VerdantRemotes:FindFirstChild("VDT_Bucket.Used")
    local PurchaseSkillRemote = VerdantRemotes and VerdantRemotes:FindFirstChild("VDT_SkillTree.Purchase")

    local TargetPrompt = nil
    pcall(function()
        TargetPrompt = workspace.Scripted.CheckpointParts["1"]:GetChildren()[3].Scripted.ProximityPosition.ProximityPrompt
    end)

    local isFarming = false
    local farmCoroutine = nil
    local tpCoroutine = nil
    local espEnabled = false
    local activeEsps = {}

    local smartBuyList = {
        {"root", 0, 0}, {"root", -1, 1}, {"buckets", 0, 1}, {"buckets", 1, 0}, 
        {"root", 1, -1}, {"root", 1, -2}, {"buckets", -1, 1}, {"buckets", 2, 0}, 
        {"buckets", 1, -1}, {"root", 0, -2}, {"root", -2, 1}, {"root", -2, 2}, 
        {"buckets", 2, -1}, {"buckets", 0, 2}, {"buckets", 1, 2}, {"root", -3, 1}, 
        {"buckets", 3, 0}, {"buckets", 2, -2}, {"buckets", 1, 1}, {"buckets", 3, -1}, 
        {"root", -3, 2}, {"root", -2, 3}, {"root", 1, -3}, {"root", 0, -3}, 
        {"buckets", 3, -2}, {"buckets", 0, -3}, {"buckets", 4, -1}, {"root", -1, -1}, 
        {"buckets", -1, 3}, {"buckets", 3, -3}, {"root", -1, -2}, {"buckets", 4, -2}, 
        {"diamonds", 0, -1}, {"diamonds", 0, -2}, {"diamonds", 1, -3}, {"diamonds", 1, -4}, 
        {"diamonds", 1, -5}, {"diamonds", -1, 2}, {"diamonds", -1, 3}, {"character", 0, -1}, 
        {"character", -1, 1}, {"character", -1, 2}, {"character", -1, 0}, {"character", -1, -1}, 
        {"character", -2, 2}, {"character", -2, 1}, {"character", -2, 0}, {"character", -3, 2}, 
        {"character", 0, 1}, {"character", 0, 2}, {"character", 1, 1}, {"character", 1, 0}, 
        {"character", 1, -1}, {"character", 1, -2}, {"character", 2, 1}, {"character", 2, 0}, 
        {"character", 2, -1}, {"character", 2, -2}, {"root", -4, -2}, {"buckets", 0, -1}, 
        {"buckets", -1, 0}, {"buckets", -1, 2}, {"buckets", 0, 3}, {"diamonds", -1, -2},
        {"diamonds", -1, -3}, {"character", 0, -2}, {"root", -4, 2}, {"root", -3, 3}
    }

    local function createChestEsp(chest)
        if activeEsps[chest] then return end
        
        local targetPart = chest:FindFirstChild("Part") or chest:FindFirstChildWhichIsA("BasePart")
        if not targetPart then return end

        local bgui = Instance.new("BillboardGui")
        bgui.Name = "ChestESP_Gui"
        bgui.AlwaysOnTop = true
        bgui.Size = UDim2.new(0, 100, 0, 30)
        bgui.StudsOffset = Vector3.new(0, 3, 0)
        bgui.Adornee = targetPart
        bgui.Parent = CoreGui

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = "Chest [" .. chest.Name .. "]"
        label.TextColor3 = Color3.fromRGB(255, 215, 0)
        label.TextSize = 14
        label.Font = Enum.Font.SourceSansBold
        label.TextStrokeTransparency = 0
        label.Parent = bgui

        local box = Instance.new("BoxHandleAdornment")
        box.Name = "ChestESP_Box"
        box.Size = targetPart.Size + Vector3.new(0.2, 0.2, 0.2)
        box.AlwaysOnTop = true
        box.ZIndex = 10
        box.Color3 = Color3.fromRGB(255, 165, 0)
        box.Transparency = 0.6
        box.Adornee = targetPart
        box.Parent = CoreGui

        activeEsps[chest] = {Bgui = bgui, Box = box}
    end

    local function removeChestEsp(chest)
        if activeEsps[chest] then
            if activeEsps[chest].Bgui then activeEsps[chest].Bgui:Destroy() end
            if activeEsps[chest].Box then activeEsps[chest].Box:Destroy() end
            activeEsps[chest] = nil
        end
    end

    local function updateEspState()
        local chestsFolder = workspace:FindFirstChild("Scripted") and workspace.Scripted:FindFirstChild("Chests")
        if not chestsFolder then return end

        if espEnabled then
            for _, chest in ipairs(chestsFolder:GetChildren()) do
                createChestEsp(chest)
            end
        else
            for chest, _ in pairs(activeEsps) do
                removeChestEsp(chest)
            end
        end
    end

    local chestsFolder = workspace:FindFirstChild("Scripted") and workspace.Scripted:FindFirstChild("Chests")
    if chestsFolder then
        chestsFolder.ChildAdded:Connect(function(child)
            if espEnabled then
                task.wait(0.1)
                createChestEsp(child)
            end
        end)
        chestsFolder.ChildRemoved:Connect(function(child)
            removeChestEsp(child)
        end)
    end

    local function fireRemotes()
        if TargetPrompt then
            pcall(function()
                PouredRemote:FireServer(TargetPrompt)
                TakeRemote:FireServer(TargetPrompt)
            end)
        end
        
        pcall(function()
            UsedRemote:FireServer()
        end)
    end

    local function teleportToWaterSplash()
        local player = Players.LocalPlayer
        local character = player.Character or player.CharacterAdded:Wait()
        local hrp = character:WaitForChild("HumanoidRootPart", 5)
        local waterSplash = workspace:FindFirstChild("WaterSplash")

        if hrp and waterSplash and waterSplash:IsA("BasePart") then
            hrp.CFrame = waterSplash.CFrame
        end
    end

    local function startFarm()
        if isFarming then return end
        isFarming = true
        
        farmCoroutine = coroutine.create(function()
            while isFarming do
                fireRemotes()
                task.wait()
            end
            farmCoroutine = nil
        end)
        coroutine.resume(farmCoroutine)

        tpCoroutine = coroutine.create(function()
            while isFarming do
                teleportToWaterSplash()
                task.wait(0.7)
            end
            tpCoroutine = nil
        end)
        coroutine.resume(tpCoroutine)
    end

    local function stopFarm()
        isFarming = false
        farmCoroutine = nil
        tpCoroutine = nil
    end

    local function collectChests()
        if not chestsFolder then return end

        local chests = chestsFolder:GetChildren()
        local player = Players.LocalPlayer
        local character = player.Character or player.CharacterAdded:Wait()
        local hrp = character:WaitForChild("HumanoidRootPart", 5)

        if not hrp then return end

        for _, chest in ipairs(chests) do
            local targetPart = chest:FindFirstChild("Part")
            if targetPart then
                local prompt = targetPart:FindFirstChild("ProximityPrompt")
                
                if prompt then
                    hrp.CFrame = targetPart.CFrame * CFrame.new(0, 3, 0)
                    task.wait(0.15) 
                    if fireproximityprompt then
                        pcall(function() fireproximityprompt(prompt) end)
                    else
                        -- Alternatif tetikleme yöntemi
                        pcall(function() prompt:InputHoldBegin() task.wait(prompt.HoldDuration) prompt:InputHoldEnd() end)
                    end
                end
            end
        end
        
        task.wait(0.1)
        teleportToWaterSplash()
    end

    -- // ---------- MACLIB MENU INTEGRATION ---------- //
    local Window = MacLib:Window({
        Title = "Blossom Scripts",
        Subtitle = "Drain the Lake",
        Size = UDim2.fromOffset(600, 500),
        AcrylicBlur = true,
        ShowUserInfo = true,
        Keybind = Enum.KeyCode.RightControl,
    })

    local TabGroup = Window:TabGroup()
    local MainTab = TabGroup:Tab({ 
        Name = "Main", 
        Image = "rbxassetid://10734950309" 
    })

    local Section = MainTab:Section({ 
        Name = "Control Panel",
        Side = "Left", 
        FullWidth = true 
    })

    local FarmToggle = Section:Toggle({
        Name = "Auto Farm",
        Default = false,
        Callback = function(state)
            if state then startFarm() else stopFarm() end
        end
    })

    local EspToggle = Section:Toggle({
        Name = "Chest ESP",
        Default = false,
        Callback = function(state)
            espEnabled = state
            updateEspState()
        end
    })

    local ChestButton = Section:Button({
        Name = "Collect Chests",
        Callback = function()
            task.spawn(collectChests)
        end
    })

    local SmartBuyButton = Section:Button({
        Name = "Smart Buy",
        Callback = function()
            if PurchaseSkillRemote and PurchaseSkillRemote:IsA("RemoteFunction") then
                task.spawn(function()
                    for _, data in ipairs(smartBuyList) do
                        local category = data[1]
                        local x = data[2]
                        local y = data[3]
                        
                        pcall(function()
                            PurchaseSkillRemote:InvokeServer(category, x, y)
                        end)
                        task.wait(0.05)
                    end
                end)
            end
        end
    })

    Window.onUnloaded(function()
        stopFarm()
        espEnabled = false
        updateEspState()
    end)

