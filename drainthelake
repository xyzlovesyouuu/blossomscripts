local isVerifying = false

-- İleride tanımlanacak fonksiyon için ön-tanımlama (Forward Declaration)
local loadMainScript

local function tryKey()
    if isVerifying then return end
    isVerifying = true
    
    local entered = keyInput.Text
    if entered == VALID_KEY then
        statusLbl.TextColor3 = Color3.fromRGB(100, 255, 150)
        statusLbl.Text = "✔ Access Granted! Loading Blossom Hub..."
        
        tween(mainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(0.5, -200, 0.5, -110),
            BackgroundTransparency = 1
        })
        tween(overlay, TweenInfo.new(0.5), {BackgroundTransparency = 1})
        
        for _, v in pairs(mainFrame:GetDescendants()) do
            if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
                tween(v, TweenInfo.new(0.4), {TextTransparency = 1, BackgroundTransparency = 1})
            elseif v:IsA("UIStroke") then
                tween(v, TweenInfo.new(0.4), {Transparency = 1})
            end
        end
        
        task.wait(0.6)
        gui:Destroy()
        loadMainScript()
    else
        statusLbl.TextColor3 = Color3.fromRGB(255, 90, 90)
        statusLbl.Text = "✘ Invalid key. Please make sure it's correct."
        
        local originalPos = UDim2.new(0.5, -200, 0.5, -140)
        tween(mainFrame, TweenInfo.new(0.04), {Position = originalPos + UDim2.new(0, 8, 0, 0)}).Completed:Wait()
        tween(mainFrame, TweenInfo.new(0.04), {Position = originalPos + UDim2.new(0, -8, 0, 0)}).Completed:Wait()
        tween(mainFrame, TweenInfo.new(0.04), {Position = originalPos + UDim2.new(0, 6, 0, 0)}).Completed:Wait()
        tween(mainFrame, TweenInfo.new(0.04), {Position = originalPos + UDim2.new(0, -6, 0, 0)}).Completed:Wait()
        tween(mainFrame, TweenInfo.new(0.04), {Position = originalPos})
        
        isVerifying = false
    end
end

confirmBtn.MouseButton1Click:Connect(tryKey)
keyInput.FocusLost:Connect(function(enter) if enter then tryKey() end end)

